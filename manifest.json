{
    "manifest_version": 3,
    "name": "WildCard",
    "version": "1.0.0",
    "description": "Build from your browser",
    "permissions": [
        "storage",
        "sidePanel",
        "tabs",
        "tabGroups",
        "bookmarks",
        "activeTab",
        "tabCapture",
        "offscreen",
        "contextMenus",
        "scripting",
        "declarativeNetRequest",
        "system.network"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "commands": {
        "toggle-recording": {
            "suggested_key": {
                "default": "Alt+Shift+R"
            },
            "description": "Toggle Audio Recording"
        }
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "side_panel": {
        "default_path": "sidebar/sidebar.html"
    },
    "action": {
        "default_title": "Open Wildcard",
        "default_icon": {
            "16": "icons/icon16.png",
            "19": "icons/icon19.png",
            "32": "icons/icon32.png",
            "38": "icons/icon38.png",
            "48": "icons/icon48.png",
            "64": "icons/icon64.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "19": "icons/icon19.png",
        "32": "icons/icon32.png",
        "38": "icons/icon38.png",
        "48": "icons/icon48.png",
        "64": "icons/icon64.png",
        "96": "icons/icon96.png",
        "128": "icons/icon128.png",
        "256": "icons/icon256.png",
        "512": "icons/icon512.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "vendor/sqlite/sql-wasm.wasm",
                "src/island.html",
                "src/island.js",
                "sidebar/local-editor.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "src/clipper.js"
            ],
            "all_frames": false,
            "run_at": "document_start"
        }
    ],
    "key": ""
}